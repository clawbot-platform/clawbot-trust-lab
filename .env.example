# Core Version 1 Compose stack
COMPOSE_PROJECT_NAME=clawbot-trust-lab-v1
POSTGRES_IMAGE=pgvector/pgvector:pg16
CONTROL_PLANE_IMAGE=ghcr.io/clawbot-platform/clawbot-server
CONTROL_PLANE_IMAGE_TAG=local
CLAWMEM_IMAGE=ghcr.io/clawbot-platform/clawmem
CLAWMEM_IMAGE_TAG=local
TRUST_LAB_IMAGE=ghcr.io/clawbot-platform/clawbot-trust-lab
TRUST_LAB_IMAGE_TAG=local
TRUST_LAB_UI_IMAGE=ghcr.io/clawbot-platform/clawbot-trust-lab-ui
TRUST_LAB_UI_IMAGE_TAG=local
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=clawbot
POSTGRES_USER=clawbot
POSTGRES_PASSWORD=clawbot
CONTROL_PLANE_HOST=127.0.0.1
CONTROL_PLANE_PORT=8081
CLAWMEM_HOST=127.0.0.1
CLAWMEM_PORT=8088
TRUST_LAB_HOST=127.0.0.1
TRUST_LAB_PORT=8090
TRUST_LAB_UI_HOST=127.0.0.1
TRUST_LAB_UI_PORT=8091
STACK_SMOKE_TIMEOUT=120
VALIDATION_OUTPUT_DIR=./version1-validation-output

# Runtime hosts should pull published GHCR images and replace the *_IMAGE_TAG
# values above with an operational release tag such as:
# - drq-v1-baseline-20260329
# - drq-v1-tuned-20260401

# Trust Lab service configuration
APP_ENV=development
SERVICE_ADDRESS=127.0.0.1:8090
LOG_LEVEL=info
SHUTDOWN_TIMEOUT=10s
CONTROL_PLANE_BASE_URL=http://127.0.0.1:${CONTROL_PLANE_PORT}
CONTROL_PLANE_TIMEOUT=5s
CLAWMEM_BASE_URL=http://127.0.0.1:${CLAWMEM_PORT}
CLAWMEM_TIMEOUT=5s
SCENARIO_PACKS_DIR=./configs/scenario-packs
REPLAY_ARCHIVE_DIR=./var/replay-archive
REPORTS_DIR=./reports
BENCHMARK_SCHEDULER_ENABLED=false
BENCHMARK_SCHEDULER_SCENARIO_FAMILY=commerce
BENCHMARK_SCHEDULER_INTERVAL=24h
BENCHMARK_SCHEDULER_MAX_RUNS=7
BENCHMARK_SCHEDULER_DRY_RUN=true

# Optional stack
# Version 1 does not ship optional services by default. If optional services are
# added later, set VALIDATE_OPTIONAL_STACK=1 when you want check-env and smoke
# commands to enforce their variables.
VALIDATE_OPTIONAL_STACK=0
