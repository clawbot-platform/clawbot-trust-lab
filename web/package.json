    "@types/node": "22.10.1",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "25.0.1",
    "typescript": "5.6.3",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  }
